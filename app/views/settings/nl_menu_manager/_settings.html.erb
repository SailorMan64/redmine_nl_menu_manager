<%
  menus = [
    { key: 'project_menu',     label: 'Project App Menu',   sub: 'Per-strategy horizontal tab bar' },
    { key: 'application_menu', label: 'Application Menu',   sub: 'Global bar above the project tabs' },
    { key: 'top_menu',         label: 'Top Menu',           sub: 'Home, Projects, My Page…' },
    { key: 'account_menu',     label: 'Account Menu',       sub: 'Next to the logged-in user badge (My account, Sign out, Help…)' }
  ]
%>

<div class="nl-menu-manager-settings">
  <div class="nl-menu-manager-intro">
    <strong>Next Level™ Menu Manager</strong> — Drag items to reorder. Toggle the checkbox to show or hide each item.
    Changes take effect immediately after saving. Per-strategy overrides are available in each strategy's Settings &gt; Modules tab.
  </div>

  <div class="nl-menu-columns">
    <% menus.each do |menu| %>
      <% items = NlMenuManager.menu_items_for_ui(menu[:key]) %>
      <div class="nl-menu-column">
        <fieldset class="box nl-menu-fieldset">
          <legend><%= menu[:label] %></legend>
          <p class="nl-menu-sub"><%= menu[:sub] %></p>
          <ul class="nl-menu-sortable" id="nl-sortable-<%= menu[:key] %>">
            <% items.each do |item| %>
              <li class="nl-menu-item" data-name="<%= item[:name] %>">
                <span class="icon-only icon-sort-handle sort-handle nl-drag-handle" title="Drag to reorder">
                  <%= sprite_icon('reorder', '') %>
                </span>
                <label class="nl-menu-label">
                  <input type="checkbox"
                         name="settings[<%= menu[:key] %>][<%= item[:name] %>][visible]"
                         value="1"
                         <%= 'checked' if item[:visible] %> /><span class="nl-menu-text"><%= item[:label] %></span><span class="nl-menu-key">(<%= item[:name] %>)</span>
                </label>
                <input type="hidden"
                       name="settings[<%= menu[:key] %>][<%= item[:name] %>][position]"
                       value="<%= item[:position] %>"
                       class="nl-position-input" />
              </li>
            <% end %>
          </ul>
        </fieldset>
      </div>
    <% end %>
  </div>
</div>
